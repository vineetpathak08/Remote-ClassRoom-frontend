# Backend URL Configuration
VITE_BACKEND_URL=https://your-backend-domain.vercel.app

# Chatbot API Configuration (Google Gemini)
VITE_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash-exp:generateContent?key=YOUR_GEMINI_API_KEY_HERE
VITE_API_TYPE=gemini

# If you use OpenAI for chatbot instead of Gemini:
# VITE_API_URL=https://api.openai.com/v1/chat/completions
# VITE_OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# For local development, uncomment the line below:
# VITE_BACKEND_URL=http://localhost:8000
